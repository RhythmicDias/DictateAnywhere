# ── Normalise line endings ────────────────────────────────────────────────────
* text=auto eol=lf

# Windows batch scripts must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ── Binary files (no diff, no merge) ─────────────────────────────────────────
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.bin   binary
*.pt    binary
*.onnx  binary

# ── Diff driver overrides ─────────────────────────────────────────────────────
*.py    diff=python
